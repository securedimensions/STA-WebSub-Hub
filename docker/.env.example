# Copy to `docker/.env` and adjust for your environment.

## Postgres (used by hub services and the postgres container)
POSTGRES_HOST=sta-websub-hub-db
POSTGRES_PORT=5432
POSTGRES_DB=websub
POSTGRES_USER=websub
POSTGRES_PASSWORD=changeme

## Hub API
HUB_PORT=4000
HUB_URL=http://localhost:4000/api/subscriptions
HUB_LOG_LEVEL=INFO

## Publisher / STA endpoints
# Base URL for WebSub discovery (HTTP HEAD) against your STA service (publisher).
STA_ROOT_URL=http://localhost:8080/FROST-Server
# MQTT broker the ingest process connects to.
STA_MQTT_URL=mqtt://localhost:1883
STA_MQTT_USER=
STA_MQTT_PASSWORD=
# Optional: if discovery is separated from STA_ROOT_URL
PUBLISHER_URL=http://localhost:8181

## Redis / BullMQ
# Note: docker-compose sets REDIS_URL internally for the hub containers, but
# setting it here is useful when running outside compose.
REDIS_URL=redis://localhost:6379
QUEUE_NAME=notifications
QUEUE_MAX_WAITING=120000
QUEUE_REMOVE_ON_COMPLETE_COUNT=10000

## Delivery worker
DELIVERY_WORKER_CONCURRENCY=100
DELIVERY_PER_CALLBACK_CONCURRENCY=20
DELIVERY_POST_TIMEOUT_MS=30000
DELIVERY_JOB_MAX_ATTEMPTS=3

## Delivery retries / backoff
DELIVERY_MAX_ATTEMPTS=3
DELIVERY_BACKOFF_BASE_MS=200

## Circuit breaker (per callback URL)
DELIVERY_CIRCUIT_FAILURE_THRESHOLD=10
DELIVERY_CIRCUIT_WINDOW_MS=60000
DELIVERY_CIRCUIT_OPEN_MS=30000

## Ops / logging
HUB_STATS_INTERVAL_MS=0
# Ingest/delivery health & metrics (compose maps these to HUB_OPS_PORT per service)
HUB_INGEST_OPS_PORT=4001
HUB_DELIVERY_OPS_PORT=4002
# Rolling window for /ops/metrics throughput (enqueued/delivered per second)
HUB_METRICS_THROUGHPUT_WINDOW_MS=10000

## Callback security policy (SSRF mitigation)
# Public subscribers recommended defaults:
# - require https callbacks
# - block private/loopback/link-local callback targets
CALLBACK_ALLOW_INSECURE_HTTP=false
CALLBACK_ALLOW_PRIVATE_NETS=false
CALLBACK_DNS_CACHE_TTL_MS=60000

## Expired subscription cleanup (sta-websub-hub-cleanup container)
# Cron schedule for npm run cleanup:expired — default every 30 minutes
CLEANUP_CRON_SCHEDULE=*/30 * * * *
