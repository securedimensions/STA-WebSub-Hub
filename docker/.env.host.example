# Copy to `docker/.env` when using docker-compose.host.yaml
# (Postgres and Redis run on the host, not in Docker).

## Postgres (on host)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=websub
POSTGRES_USER=websub
POSTGRES_PASSWORD=changeme

## Hub API
HUB_PORT=4000
HUB_URL=http://localhost:4000/api/subscriptions
HUB_LOG_LEVEL=INFO
# Required: token for all /ops endpoints (GET /ops/metrics, /ops/failed, POST /ops/failed/*, etc.)
# Generate with: openssl rand -hex 32
HUB_OPS_TOKEN=
# Required: 64-char hex key for AES-256-GCM encryption of hub.secret values at rest.
# Generate with: openssl rand -hex 32
HUB_SECRET_KEY=

## Publisher / STA endpoints
STA_ROOT_URL=http://host.docker.internal:8080/FROST-Server
STA_MQTT_URL=mqtt://host.docker.internal:1883
STA_MQTT_USER=
STA_MQTT_PASSWORD=
PUBLISHER_URL=http://host.docker.internal:8181

## Redis (on host)
REDIS_URL=redis://host.docker.internal:6379
QUEUE_NAME=notifications
QUEUE_MAX_WAITING=120000
QUEUE_REMOVE_ON_COMPLETE_COUNT=10000

## Delivery worker
DELIVERY_WORKER_CONCURRENCY=100
DELIVERY_PER_CALLBACK_CONCURRENCY=20
DELIVERY_POST_TIMEOUT_MS=30000
DELIVERY_JOB_MAX_ATTEMPTS=3
DELIVERY_MAX_ATTEMPTS=3
DELIVERY_BACKOFF_BASE_MS=200

## Circuit breaker
DELIVERY_CIRCUIT_FAILURE_THRESHOLD=10
DELIVERY_CIRCUIT_WINDOW_MS=60000
DELIVERY_CIRCUIT_OPEN_MS=30000

## Expired subscription cleanup
CLEANUP_CRON_SCHEDULE=*/30 * * * *

## Callback security policy (SSRF mitigation)
CALLBACK_ALLOW_INSECURE_HTTP=false
CALLBACK_ALLOW_PRIVATE_NETS=false
CALLBACK_DNS_CACHE_TTL_MS=60000

## Ops / logging
HUB_STATS_INTERVAL_MS=1000
