# Copy to test/.env and adjust if needed.
# These values are used by both the test docker-compose (picked up automatically
# when running docker compose from the test/ directory) and the npm test process.

# Hub API — the only service exposed to the host for test HTTP requests.
HUB_PORT=4000

# Security tokens — must match what hub-api receives inside the container.
HUB_OPS_TOKEN=test-ops-token
HUB_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# PostgreSQL — the test process connects to the host-mapped port directly.
# POSTGRES_PORT_HOST is the host-side port (mapped to container port 5432).
# Use a non-default value to avoid clashing with a local postgres installation.
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_PORT_HOST=15432
POSTGRES_USER=websub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=websub
