# Copy to test/.env and adjust if needed.
# Docker Compose reads this file automatically when run from the test/ directory.
# All services communicate inside the WebSubHubTest network — no host port
# mappings are used, so these values only affect container-internal behaviour.

# Hub API port (used inside the WebSubHubTest network).
HUB_PORT=4000

# Security tokens injected into hub-api and the test-runner.
# Must match between the two services.
HUB_OPS_TOKEN=test-ops-token
HUB_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SUBSCRIBER_URL=http://subscriber:8081
